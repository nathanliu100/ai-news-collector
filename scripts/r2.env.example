# Cloudflare R2 凭证（复制为 r2.env 后填写；r2.env 已被 .gitignore 忽略，不进仓库）
# S3 兼容 API 直连方式，不依赖 wrangler

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# 桶的公开访问域名（R2 桶 Settings → Public Development URL → Enable 后生成）
# 形如 https://pub-xxxxxxxx.r2.dev
R2_PUBLIC_BASE=

# ── 如何获取 ──
# R2_ACCOUNT_ID:        R2 桶的 S3 endpoint URL https://<这串>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID:     创建 R2 API Token 时给的 Access Key ID
# R2_SECRET_ACCESS_KEY: 同上的 Secret Access Key（只显示一次）
# R2_BUCKET:            桶名（R2 Overview 列表里的 Name）
# R2_PUBLIC_BASE:       桶 Settings 里 Enable Public Development URL 后的 pub-xxx.r2.dev
